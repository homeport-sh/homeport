---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import { config } from "virtual:nimbus/config";
---

<BaseLayout title={config.title} description={config.description}>
  <div class="flex flex-col min-h-screen">
    <Header />
    <main class="flex-1 mx-auto max-w-2xl w-full px-6 py-24">
      <h1
        class="text-foreground leading-tight"
        style="font-size: var(--nb-h1-size); font-weight: var(--nb-h1-weight); letter-spacing: var(--nb-h1-tracking);"
      >
        {config.title}
      </h1>
      <p class="mt-2 text-[1.0625rem] text-muted-foreground leading-relaxed">
        {config.description}
      </p>

      <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-3">
        <a
          href="/introduction"
          class="block rounded-lg border border-border p-4 transition-colors hover:border-border-strong no-underline"
        >
          <div class="font-medium text-foreground">Introduction</div>
          <div class="mt-0.5 text-sm text-muted-foreground">What & why</div>
        </a>
        <a
          href="/quick-start"
          class="block rounded-lg border border-border p-4 transition-colors hover:border-border-strong no-underline"
        >
          <div class="font-medium text-foreground">Quick start</div>
          <div class="mt-0.5 text-sm text-muted-foreground">Bare box → live app</div>
        </a>
        <a
          href="/configuration"
          class="block rounded-lg border border-border p-4 transition-colors hover:border-border-strong no-underline"
        >
          <div class="font-medium text-foreground">Configuration</div>
          <div class="mt-0.5 text-sm text-muted-foreground">homeport.yaml reference</div>
        </a>
      </div>
    </main>
  </div>
</BaseLayout>
